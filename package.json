{
  "name": "my-node-app",
  "version": "1.0.0",
  "description": "Simple Node.js REST API for Jenkins CI/CD demo",
  "main": "src/server.js",
  "scripts": {
    "start":   "node src/server.js",
    "dev":     "nodemon src/server.js",
    "test":    "jest --coverage",
    "lint":    "eslint src/**/*.js"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest":      "^29.5.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["src/**/*.js"]
  }
}